    function renderProtocols() {
        const container = document.getElementById('protocolsGrid');
        container.innerHTML = protocols.map(p => `
            <div class="protocol-card" style="background:rgba(15,5,25,0.8); border-left:4px solid #aa44ff; border-radius:12px; padding:1rem; cursor:pointer;" onclick="showProtocol('${p.name}', '${p.title}', '${p.desc}')">
                <i class="fas fa-scroll text-purple-400 mr-2"></i>
                <strong>ПРОТОКОЛ ${p.name}</strong> — ${p.title}
                <i class="fas fa-chevron-right text-xs ml-2 text-purple-400"></i>
            </div>
        `).join('');
    }
    
    function renderOperations() {
        const container = document.getElementById('operationsGrid');
        container.innerHTML = operations.map(op => `
            <div class="tau-card" style="cursor:pointer;" onclick="showOperation('${op.name}', '${op.year}', '${op.obj}', '${op.desc}')">
                <i class="fas fa-dragon text-purple-400 text-xl"></i>
                <h3 class="font-bold mt-1">${op.name}</h3>
                <p class="text-xs text-gray-400 mt-1">${op.obj} · ${op.year}</p>
                <p class="text-sm text-gray-300 mt-2">${op.desc.substring(0, 80)}...</p>
                <span class="text-purple-400 text-xs">подробнее →</span>
            </div>
        `).join('');
    }
    
    function renderTechSpecs() {
        const container = document.getElementById('techSpecs');
        container.innerHTML = techSpecs.map(s => `<div class="text-sm">${s}</div>`).join('');
    }
    
    // ============= МОДАЛЬНЫЕ ОКНА =============
    window.showMember = function(name, role, bio, cycles) {
        const modal = document.getElementById('infoModal');
        const content = document.getElementById('modalContent');
        content.innerHTML = `
            <div class="border-b border-purple-800 pb-3 mb-3">
                <i class="fas fa-user-astronaut text-3xl text-purple-400 mb-2"></i>
                <h2 class="text-2xl font-bold">${name}</h2>
                <span class="tech-badge">${role}</span>
            </div>
            <p class="text-gray-300 leading-relaxed">${bio}</p>
            <div class="blood-code mt-4 text-xs">
                <i class="fas fa-dharmachakra"></i> Статус: АКТИВЕН<br>
                <i class="fas fa-sync-alt"></i> Циклов перерождения: ${cycles}<br>
                <i class="fas fa-shield-alt"></i> Боевая готовность: 100%
            </div>
        `;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        playCardSound();
    };
    
    window.showProtocol = function(code, title, desc) {
        const modal = document.getElementById('infoModal');
        const content = document.getElementById('modalContent');
        content.innerHTML = `
            <div class="border-b border-purple-800 pb-3 mb-3">
                <i class="fas fa-scroll text-3xl text-purple-400 mb-2"></i>
                <h2 class="text-xl font-bold">ПРОТОКОЛ ${code}</h2>
                <span class="tech-badge">${title}</span>
            </div>
            <div class="blood-code whitespace-pre-line text-sm">${desc}</div>
            <div class="mt-4 text-xs text-purple-400 text-center">[ АВТОРИЗОВАНО: СОВЕТ О5 ]</div>
        `;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        playCardSound();
    };
    
    window.showOperation = function(name, year, obj, desc) {
        const modal = document.getElementById('infoModal');
        const content = document.getElementById('modalContent');
        content.innerHTML = `
            <div class="border-b border-purple-800 pb-3 mb-3">
                <i class="fas fa-skull text-3xl text-purple-400 mb-2"></i>
                <h2 class="text-xl font-bold">${name}</h2>
                <span class="tech-badge">${obj} · ${year}</span>
            </div>
            <p class="text-gray-300 leading-relaxed">${desc}</p>
            <div class="mt-4 p-3 bg-black/40 rounded-lg text-xs font-mono">
                <i class="fas fa-chart-line"></i> Эффективность: 94.7%<br>
                <i class="fas fa-heartbeat"></i> Потери: временные (восстановлены)
            </div>
        `;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        playCardSound();
    };
    
    window.closeModal = function() {
        document.getElementById('infoModal').style.display = 'none';
        document.body.style.overflow = 'auto';
    };
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeModal();
    });
    
    // ============= ПАРАЛЛАКС =============
    document.addEventListener('mousemove', function(e) {
        const layer = document.getElementById('parallaxLayer');
        const x = (e.clientX / window.innerWidth - 0.5) * 20;
        const y = (e.clientY / window.innerHeight - 0.5) * 20;
        layer.style.transform = `translate(${x}px, ${y}px)`;
    });
    
    // ============= АНИМАЦИИ ПОЯВЛЕНИЯ =============
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });
    
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    
    // ============= ЗАГРУЗОЧНЫЙ ЭКРАН =============
    let dotCount = 0;
    const loaderInterval = setInterval(() => {
        dotCount = (dotCount + 1) % 4;
        const dots = '.'.repeat(dotCount);
        const loaderDots = document.getElementById('loaderDots');
        if (loaderDots) loaderDots.textContent = dots;
    }, 300);
    
    window.addEventListener('load', function() {
        setTimeout(() => {
            const loader = document.getElementById('loader');
            if (loader) {
                loader.style.opacity = '0';
                setTimeout(() => {
                    loader.style.display = 'none';
                    clearInterval(loaderInterval);
                }, 1000);
            }
        }, 1500);
        
        // Активировать звук при первом клике
        setTimeout(() => {
            const badge = document.getElementById('accessBadge');
            if (badge) {
                badge.style.animation = 'glitch 0.5s infinite';
                setTimeout(() => badge.style.animation = '', 2000);
            }
        }, 2000);
    });
    
    // ============= ИНИЦИАЛИЗАЦИЯ =============
    renderMembers();
    renderProtocols();
    renderOperations();
    renderTechSpecs();
    
    // Счетчик реинкарнаций с анимацией
    let count = 247;
    const counterInterval = setInterval(() => {
        count++;
        const el = document.getElementById('reincarnationCount');
        if (el) el.textContent = count;
        if (count > 289) clearInterval(counterInterval);
    }, 30000);
    
    console.log("%c⚠️ ТЕРМИНАЛ МОГ ТАУ-5 «САМСАРА» АКТИВИРОВАН ⚠️", "color: #aa44ff; font-size: 14px; font-family: monospace");
    console.log("%cБессмертные воины из плоти мёртвого бога. Смерть — временное состояние.", "color: #b87cff; font-size: 12px");
</script>
