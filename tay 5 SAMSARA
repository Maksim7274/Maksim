    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #010001;
            color: #d0d0e8;
            overflow-x: hidden;
            cursor: default;
        }

        /* Сканирующая линия */
        .scan-line {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9999;
            background: linear-gradient(to bottom, transparent 0%, rgba(100, 50, 150, 0.03) 50%, transparent 100%);
            animation: scanMove 8s linear infinite;
        }

        @keyframes scanMove {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(100%); }
        }

        /* Биомеханический фон с параллаксом */
        .bio-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: radial-gradient(circle at 30% 40%, #0a0518 0%, #020005 100%);
        }
        
        .parallax-layer {
            position: fixed;
            top: 0;
            left: 0;
            width: 110%;
            height: 110%;
            z-index: -1;
            pointer-events: none;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 800"><path fill="none" stroke="rgba(120,60,180,0.15)" stroke-width="1" d="M100,100 L700,100 M100,200 L700,200 M100,300 L700,300 M100,400 L700,400 M100,500 L700,500 M100,600 L700,600 M100,700 L700,700 M200,100 L200,700 M300,100 L300,700 M400,100 L400,700 M500,100 L500,700 M600,100 L600,700 M700,100 L700,700"/><circle cx="400" cy="400" r="50" fill="none" stroke="rgba(150,80,200,0.1)" stroke-width="1"/><circle cx="400" cy="400" r="100" fill="none" stroke="rgba(150,80,200,0.05)"/></svg>');
            background-repeat: repeat;
            background-size: 80px;
            opacity: 0.4;
            transition: transform 0.1s ease-out;
        }

        /* Глитч-эффект */
        .glitch-text {
            position: relative;
            animation: glitch 3s infinite;
        }
        
        @keyframes glitch {
            0%, 100% { text-shadow: 0.02em 0 0 rgba(150,0,255,0.5), -0.02em 0 0 rgba(0,255,255,0.5); }
            25% { text-shadow: -0.02em 0 0 rgba(150,0,255,0.7), 0.02em 0 0 rgba(0,255,255,0.7); }
            50% { text-shadow: 0.03em 0 0 rgba(150,0,255,0.4), -0.03em 0 0 rgba(0,255,255,0.4); }
            75% { text-shadow: -0.01em 0 0 rgba(150,0,255,0.8), 0.01em 0 0 rgba(0,255,255,0.8); }
        }

        /* Карточки с hover-эффектами */
        .tau-card {
            background: linear-gradient(135deg, rgba(20, 8, 40, 0.85), rgba(8, 3, 20, 0.95));
            border: 1px solid #5a2c8a;
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            cursor: pointer;
            backdrop-filter: blur(4px);
        }
        
        .tau-card:hover {
            border-color: #b87cff;
            box-shadow: 0 0 30px rgba(120, 60, 180, 0.4), inset 0 0 20px rgba(120, 60, 180, 0.1);
            transform: translateY(-8px) scale(1.02);
        }
        
        /* Системный интерфейс */
        .terminal-header {
            background: rgba(0, 0, 0, 0.7);
            border-bottom: 1px solid #6a3c9a;
            font-family: 'Courier Prime', monospace;
        }
        
        .status-led {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #6eff8e;
            box-shadow: 0 0 5px #6eff8e;
            animation: pulse 1.5s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }
        
        /* Модальное окно с анимацией */
        .tau-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.96);
            backdrop-filter: blur(12px);
            z-index: 10000;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; backdrop-filter: blur(0); }
            to { opacity: 1; backdrop-filter: blur(12px); }
        }
        
        .modal-container {
            max-width: 550px;
            width: 90%;
            background: linear-gradient(135deg, #0c0518, #050210);
            border: 1px solid #aa44ff;
            border-radius: 24px;
            padding: 2rem;
            max-height: 85vh;
            overflow-y: auto;
            animation: slideUp 0.3s ease;
            box-shadow: 0 0 50px rgba(170, 68, 255, 0.2);
        }
        
        @keyframes slideUp {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        .close-modal {
            position: absolute;
            top: 15px;
            right: 25px;
            font-size: 32px;
            cursor: pointer;
            color: #aa44ff;
            transition: 0.2s;
        }
        
        .close-modal:hover {
            color: #ff88ff;
            transform: scale(1.1);
        }
        
        /* Анимация появления элементов */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }
        
        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* Технические бейджи */
        .tech-badge {
            font-family: 'Courier Prime', monospace;
            background: #2a1a3a;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            color: #b87cff;
            border: 1px solid #6a4c8a;
        }
        
        .blood-code {
            font-family: 'Courier Prime', monospace;
            background: #1a0a2a;
            padding: 1rem;
            border-radius: 12px;
            color: #cc88ff;
            font-size: 0.8rem;
        }
        
        .btn-tau {
            background: transparent;
            border: 1px solid #aa44ff;
            color: #c98cff;
            padding: 8px 28px;
            border-radius: 40px;
            transition: 0.2s;
            cursor: pointer;
            font-weight: 500;
        }
        
        .btn-tau:hover {
            background: #aa44ff;
            color: black;
            box-shadow: 0 0 20px #aa44ff;
            transform: scale(1.02);
        }
        
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0a0515; }
        ::-webkit-scrollbar-thumb { background: #aa44ff; border-radius: 10px; }
        
        @media (max-width: 768px) {
